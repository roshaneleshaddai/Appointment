datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

enum Mode {
  ONLINE
  OFFLINE
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Patient {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  contact      String
  dob          DateTime
  email        String        @unique
  password     String
  appointments Appointment[]
}

model Doctor {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String           @unique
  password     String
  specialty    String           // e.g., "Cardiology", "Dermatology"
  mode         Mode             // STRICT RULE: Enforces Online OR Offline exclusively
  fee          Float
  active       Boolean          @default(true)
  schedules    DoctorSchedule[]
  appointments Appointment[]
}

model DoctorSchedule {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  doctorId    String        @db.ObjectId
  doctor      Doctor        @relation(fields: [doctorId], references: [id])
  date        DateTime      // Only the Date (e.g., 2023-11-25)
  timeSlot    String        // e.g., "10:00 AM - 10:30 AM"
  bookedFlag  Boolean       @default(false)
  
  appointment Appointment?  
}

model Appointment {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  patientId        String            @db.ObjectId
  patient          Patient           @relation(fields: [patientId], references: [id])
  doctorId         String            @db.ObjectId
  doctor           Doctor            @relation(fields: [doctorId], references: [id])
  scheduleId       String            @unique @db.ObjectId
  schedule         DoctorSchedule    @relation(fields: [scheduleId], references: [id])
  
  mode             Mode              // Copied from Doctor at time of booking
  status           AppointmentStatus @default(SCHEDULED)
  fee              Float
  
  // Either a video link OR a physical address depending on the mode
  linkOrAddress    String?           

  createdAt        DateTime          @default(now())
}
